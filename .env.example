# Used only by the local Vite dev server proxy; not embedded in the browser.
API_DEV_SERVER="http://localhost:8787"

# Optional browser analytics. Leave blank to disable the corresponding provider.
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
VITE_CLARITY_PROJECT_ID="your-clarity-project-id"
VITE_TURNSTILE_SITE_KEY="your-turnstile-site-key"

# Hono/Vercel server variables. Copy this file to .env.local for local API work.
ALLOWED_ORIGINS="http://localhost:3000"
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
TURNSTILE_SECRET_KEY="YOUR_TURNSTILE_SECRET_KEY"
